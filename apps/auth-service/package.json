{
  "name": "@free-compute/auth-service",
  "version": "0.1.0",
  "private": true,
  "description": "Authentication and session service for Free-Compute",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "node --test --loader ts-node/esm test/**/*.test.ts"
  },
  "dependencies": {
    "express": "4.21.2",
    "jsonwebtoken": "9.0.2"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "20.17.6",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.6.3"
  }
}
