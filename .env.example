# ── FreeCompute Environment Configuration ──
# Copy this to .env and fill in your values.

# ── Gateway ──
FREECOMPUTE_GATEWAY_ADDR=:8080
# Bootstrap admin user (default: admin)
FREECOMPUTE_ADMIN_EMAIL=admin
FREECOMPUTE_TUNNEL_TOKEN=dev-token-$(date +%s)

# Tunnel routes (JSON array — see run-backend.sh for default)
FREECOMPUTE_TUNNEL_ROUTES=[{"id":"web","protocol":"http","target":"http://localhost:3000"},{"id":"api","protocol":"http","target":"http://localhost:8081"}]

# Proxy timeouts
FREECOMPUTE_GATEWAY_SHUTDOWN_SECONDS=5
FREECOMPUTE_TUNNEL_DIAL_SECONDS=3
FREECOMPUTE_TUNNEL_AGENT_WAIT_SECONDS=5
FREECOMPUTE_GATEWAY_READ_HEADER_SECONDS=3
FREECOMPUTE_GATEWAY_IDLE_SECONDS=60
FREECOMPUTE_PROXY_UPSTREAM_IDLE_SECONDS=30
FREECOMPUTE_PROXY_RESPONSE_HEADER_SECONDS=5
FREECOMPUTE_PROXY_EXPECT_CONTINUE_SECONDS=1
FREECOMPUTE_PROXY_MAX_IDLE_CONNS=8192
FREECOMPUTE_PROXY_MAX_IDLE_CONNS_PER_HOST=1024
FREECOMPUTE_PROXY_FLUSH_MS=-1

# Database
FREECOMPUTE_DB_PATH=/tmp/freecompute.db

# TCP/UDP buffer tuning
FREECOMPUTE_TCP_BUFFER_SIZE=8388608
FREECOMPUTE_UDP_BUFFER_SIZE=16777216

# Optional LLM moderation (empty = heuristic only)
FREECOMPUTE_MODERATION_LLM_URL=
FREECOMPUTE_MODERATION_LLM_KEY=

# DNS cache tuning
FREECOMPUTE_DNS_TTL_SECONDS=600
FREECOMPUTE_DNS_MAX_ENTRIES=4096

# Security & rate limiting
FREECOMPUTE_RATE_LIMIT_RPM=2000
FREECOMPUTE_MAX_CONNS_PER_USER=100
FREECOMPUTE_DEFAULT_BROWSING_MODE=casual
FREECOMPUTE_ADMIN_EMAIL=admin
FREECOMPUTE_ADMIN_ROLE=admin

# Admin password is auto-generated if FREECOMPUTE_ADMIN_PASSWORD is not set

# BunnyCDN edge hostnames
FREECOMPUTE_CDN_HOSTNAME=cdn.freecompute.io
FREECOMPUTE_EDGE_HOSTNAME=edge.freecompute.io
FREECOMPUTE_API_HOSTNAME=api.freecompute.io

# ── Host Agent ──
FREECOMPUTE_AGENT_GATEWAY_URL=http://localhost:8080
FREECOMPUTE_AGENT_TOKEN=${FREECOMPUTE_TUNNEL_TOKEN}
FREECOMPUTE_AGENT_ROUTES=[{"id":"vm-ssh","target":"localhost:22"},{"id":"vm-tcp","target":"localhost:8082"}]
FREECOMPUTE_AGENT_DIAL_SECONDS=5
FREECOMPUTE_AGENT_RECONNECT_SECONDS=1
FREECOMPUTE_AGENT_INSECURE_SKIP_TLS=0

# ── VM Agent (vm-setup) ──
FREECOMPUTE_GATEWAY_URL=http://localhost:8080
FREECOMPUTE_AGENT_TOKEN=${FREECOMPUTE_TUNNEL_TOKEN}
FREECOMPUTE_VM_ID=vm-test-001
FREECOMPUTE_VM_REGION=us-east-1
FREECOMPUTE_VM_GPU_ENABLED=true
FREECOMPUTE_VM_GPU_MODEL=
FREECOMPUTE_VM_GPU_VRAM=0
FREECOMPUTE_VM_CPUCORES=8
FREECOMPUTE_VM_RAMGB=32
FREECOMPUTE_VM_STORAGEGB=500
FREECOMPUTE_VM_ENABLE_WEBRTC=true
FREECOMPUTE_VM_ENABLE_GAMING=true
FREECOMPUTE_VM_ENABLE_REMOTE_SUPPORT=true
FREECOMPUTE_VM_AUDIO=true
FREECOMPUTE_VM_DISPLAY_PORT=0
FREECOMPUTE_VM_ROUTES=[{"id":"desktop-ssh","protocol":"ssh","target":"127.0.0.1","port":22,"poolSize":4},{"id":"desktop-http","protocol":"http","target":"127.0.0.1","port":8080,"poolSize":2}]
