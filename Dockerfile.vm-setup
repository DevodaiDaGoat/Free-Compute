FROM golang:1.24-alpine AS builder
WORKDIR /src
RUN apk add --no-cache git ca-certificates
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /freecompute-vm-setup ./cmd/vm-setup

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /freecompute-vm-setup /freecompute-vm-setup
ENTRYPOINT ["/freecompute-vm-setup"]
